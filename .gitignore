# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.nbconvert.ipynb

# Environment variables / secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / editors
.vscode/
.idea/
*.swp
*.swo

# Data files - keep raw/interim/processed data out of Git
# Reproducibility should come from scripts and documented data sources.
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Generated outputs
outputs/tables/*
outputs/figures/*
outputs/factor_returns/*
!outputs/tables/.gitkeep
!outputs/figures/.gitkeep
!outputs/factor_returns/.gitkeep

# Common data formats
*.csv
*.xlsx
*.xls
*.parquet
*.feather
*.pkl
*.pickle
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# Temporary files
tmp/
temp/
*.tmp
